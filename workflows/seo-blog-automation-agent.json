      "name": "Code (Prepare Competitor URLs)"
    },
    {
      "parameters": {
        "jsCode": "const cleaned = [];\n\nfor (const item of $input.all()) {\n  let text = item.json.data?.markdown || \"\";\n\n  // Remove images\n  text = text.replace(/!\\[.*?\\]\\(.*?\\)/g, \"\");\n\n  // Remove links but keep anchor text\n  text = text.replace(/\\[([^\\]]+)\\]\\((.*?)\\)/g, \"$1\");\n\n  // Remove HTML tags\n  text = text.replace(/<[^>]*>/g, \"\");\n\n  // Remove excessive whitespace\n  text = text.replace(/\\n{3,}/g, \"\\n\\n\");\n\n  // Remove common unwanted sections\n  const stopSections = [\n    \"Disqus Comments\",\n    \"Join the discussion\",\n    \"Share\",\n    \"Membership\",\n    \"Comments\",\n    \"Related articles\",\n    \"You might also like\",\n    \"Subscribe\",\n    \"Newsletter\"\n  ];\n\n  for (const stop of stopSections) {\n    const index = text.indexOf(stop);\n    if (index !== -1) {\n      text = text.substring(0, index);\n    }\n  }\n\n  // IMPORTANT: limit size before sending to AI\n  if (text.length > 6000) {\n    text = text.substring(0, 6000);\n  }\n\n  cleaned.push({\n    json: {\n      article: text.trim()\n    }\n  });\n}\n\nreturn cleaned;"
      },
