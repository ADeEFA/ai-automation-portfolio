      "parameters": {
        "jsCode": "let combinedArticles = \"\";\n\nitems.forEach((item, index) => {\n\n  // Get article safely\n  let article = item.json.article || \"\";\n\n  // Remove extra spaces and line breaks\n  article = article.replace(/\\s+/g, \" \").trim();\n\n  // Limit each competitor article length\n  article = article.slice(0, 3000);\n\n  combinedArticles += `Competitor ${index + 1}:\\n${article}\\n\\n`;\n\n});\n\n// Limit the total size sent to the AI\ncombinedArticles = combinedArticles.slice(0, 12000);\n\nreturn [\n  {\n    json: {\n      query: items[0].json.query,\n      competitor_articles: combinedArticles\n    }\n  }\n];"
      },
