      "parameters": {
        "jsCode": "// Get the raw output from the AI Agent\nconst rawOutput = $json.output;\n\n// Convert the string into actual JSON\nconst parsedData = JSON.parse(rawOutput);\n\n// Transform to a new schema\nconst formattedLeads = parsedData.map(place => {\n  return {\n    business_name: place[\"Name\"] || null,\n    address: place[\"Address\"] || null,\n    phone: place[\"Phone\"] || null,\n    website: place[\"Website\"] || null,\n    rating: place[\"Rating\"] ? Number(place[\"Rating\"]) : null,\n    opening_hours: place[\"Opening Hours\"] || null\n  };\n});\n\n// Return the structured data\nreturn formattedLeads.map(item => ({ json: item }));"
      },
